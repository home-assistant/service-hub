# Copy to `.env` and fill in. Bun auto-loads `.env` at startup.

# --- GitHub App (required) ---
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=
# PEM private key. Keep it on one line wrapped in double quotes, using \n for
# newlines — e.g. "-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_PRIVATE_KEY=

# --- Discord (optional; leave blank to run GitHub-only) ---
DISCORD_TOKEN=

# --- Sentry (optional; leave blank to disable) ---
SENTRY_DSN=

# --- Bot identity (optional; defaults shown) ---
# Must match the GitHub App's URL slug. `[bot]` is appended at runtime.
BOT_SLUG=home-assistant
# Comment-command prefix: the bot reacts to `/${COMMAND_SLUG} <command>`.
COMMAND_SLUG=ha-bot

# --- Runtime (optional; defaults shown) ---
ENVIRONMENT=production
PORT=8787
