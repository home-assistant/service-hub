{
  "collection": "@nestjs/schematics",
  "sourceRoot": "services/bots/src",
  "monorepo": true,
  "root": "services/bots",
  "compilerOptions": {
    "webpack": true,
    "tsConfigPath": "services/bots/tsconfig.app.json"
  },
  "projects": {
    "bots": {
      "type": "application",
      "root": "services/bots",
      "entryFile": "main",
      "sourceRoot": "services/bots/src",
      "compilerOptions": {
        "tsConfigPath": "services/bots/tsconfig.app.json"
      }
    }
  }
}