{
  "name": "ha-github-bot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "check": "biome check . && tsc --noEmit",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "capture": "tsx scripts/capture-webhooks.ts",
    "scrub": "tsx scripts/capture-webhooks.ts scrub",
    "capture-discord": "tsx scripts/capture-discord.ts",
    "sync-templates": "tsx scripts/sync-templates.ts"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks-methods": "^6.0.0",
    "@octokit/webhooks-types": "^7.6.1",
    "@sentry/node": "^10.65.0",
    "discord.js": "^14.26.5",
    "tsx": "^4.23.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
