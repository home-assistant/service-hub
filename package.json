{
  "name": "ha-github-bot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun src/server.ts",
    "dev": "bun --watch src/server.ts",
    "check": "biome check . && tsc --noEmit",
    "format": "biome check --write .",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "capture": "bun scripts/capture-webhooks.ts",
    "scrub": "bun scripts/capture-webhooks.ts scrub",
    "capture-discord": "bun scripts/capture-discord.ts",
    "sync-templates": "bun scripts/sync-templates.ts",
    "update-fixture-bodies": "bun scripts/update-fixture-bodies.ts"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks-methods": "^6.0.0",
    "@octokit/webhooks-types": "^7.6.1",
    "@sentry/bun": "^10.51.0",
    "discord.js": "^14.26.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/bun": "^1.2.0",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0"
  }
}
