{
  "name": "ha-github-bot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "check": "biome check . && tsc --noEmit",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "capture": "tsx scripts/capture-webhooks.ts",
    "scrub": "tsx scripts/capture-webhooks.ts scrub",
    "capture-discord": "tsx scripts/capture-discord.ts",
    "sync-templates": "tsx scripts/sync-templates.ts",
    "update-fixture-bodies": "tsx scripts/update-fixture-bodies.ts"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks-methods": "^6.0.0",
    "@octokit/webhooks-types": "^7.6.1",
    "@sentry/node": "^10.51.0",
    "discord.js": "^14.26.4",
    "tsx": "^4.20.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
